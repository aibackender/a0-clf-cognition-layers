{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cognition Layers Checkpoint",
  "type": "object",
  "required": ["id", "created_at", "schema_version", "spec_version"],
  "properties": {
    "id": { "type": "string" },
    "context_id": { "type": ["string", "null"] },
    "scope": { "type": "object" },
    "profile_status": { "type": "object" },
    "recent_verification_results": { "type": "array", "items": { "type": "object" } },
    "recent_patterns": { "type": "array", "items": { "type": "object" } },
    "recent_correction_decisions": { "type": "array", "items": { "type": "object" } },
    "correction_runtime_state": {
      "type": "object",
      "properties": {
        "attempt_counter": { "type": "object", "additionalProperties": { "type": "integer" } },
        "recent_failures": { "type": "object", "additionalProperties": { "type": "integer" } },
        "pending_guidance": { "type": "array", "items": { "type": "object" } },
        "last_history_trigger": { "type": ["string", "null"] },
        "last_correction_state": { "type": ["string", "null"] },
        "last_decision": { "type": ["object", "null"] },
        "mode": { "type": "string" },
        "schema_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "prompt_budget": { "type": "object" },
    "metadata": { "type": "object" },
    "schema_version": { "type": "string" },
    "spec_version": { "type": "string" },
    "created_at": { "type": "string" }
    ,
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
