{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cognition Layers Pattern Record",
  "anyOf": [
    {
      "type": "object",
      "required": ["id", "type", "pattern", "confidence", "firstObserved", "lastObserved", "evidence", "status", "metadata", "storageLayer", "schema_version", "spec_version"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["improvement", "error"] },
        "pattern": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "firstObserved": { "type": "string" },
        "lastObserved": { "type": "string" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["observation", "source", "observedAt"],
            "properties": {
              "observation": { "type": "string" },
              "source": { "type": "string" },
              "observedAt": { "type": "string" },
              "toolName": { "type": ["string", "null"] },
              "scope": { "type": "object" },
              "metadata": { "type": "object" }
            },
            "additionalProperties": true
          }
        },
        "mitigation": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["candidate", "promoted", "verified", "active", "deprecated", "archived", "rejected"] },
        "metadata": { "type": "object" },
        "storageLayer": { "type": "string", "enum": ["L1_SESSION", "L2_AGENT", "L3_SHARED"] },
        "schema_version": { "type": "string" },
        "spec_version": { "type": "string" },
        "updated_at": { "type": ["string", "null"] },
        "usage_count": { "type": "integer", "minimum": 1 },
        "kind": { "type": "string" },
        "summary": { "type": "string" },
        "title": { "type": "string" },
        "scope": { "type": "object" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "tool_name": { "type": ["string", "null"] },
        "source_tool": { "type": ["string", "null"] },
        "trigger": { "type": ["string", "null"] },
        "source_phase": { "type": ["string", "null"] },
        "created_at": { "type": "string" },
        "last_confirmed_at": { "type": ["string", "null"] },
        "decay_score": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["id", "kind", "confidence", "source_phase", "summary", "created_at", "schema_version"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string", "enum": ["success", "failure", "unsafe", "safe", "workaround"] },
        "type": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_phase": { "type": "string" },
        "tool_name": { "type": ["string", "null"] },
        "source_tool": { "type": ["string", "null"] },
        "trigger": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"] },
        "summary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "scope": { "type": "object" },
        "created_at": { "type": "string" },
        "updated_at": { "type": ["string", "null"] },
        "last_confirmed_at": { "type": ["string", "null"] },
        "decay_score": { "type": "number", "minimum": 0 },
        "usage_count": { "type": "integer", "minimum": 0 },
        "schema_version": { "type": "string" }
      },
      "additionalProperties": true
    }
  ]
}
